---
import { type CollectionEntry, render } from "astro:content";
import { Image } from "astro:assets";

import ShareButtons from "@/components/blog/ShareButtons.astro";
import { getAllPosts, sortMDByDate } from "@/data/post";
import { siteConfig } from "@/site-config";
import { formatBylineDate, formatEyebrowDate } from "@/utils/date";
import { absoluteUrl, withBase } from "@/utils/path";
import "katex/dist/katex.min.css";

import BaseLayout from "./Base.astro";
import { Schema } from "astro-seo-schema";

interface Props {
	post: CollectionEntry<"post">;
}

const { post } = Astro.props;

const sortedAll = sortMDByDate(await getAllPosts());
const idx = sortedAll.findIndex((p) => p.id === post.id);
const newerPost = idx > 0 ? sortedAll[idx - 1] : undefined;
const olderPost = idx >= 0 && idx < sortedAll.length - 1 ? sortedAll[idx + 1] : undefined;
const {
	data: { coverImage, description, publishDate, title, updatedDate, tags, draft, ogImage },
	id: slug,
} = post;

const ogImageUrl = ogImage
	? absoluteUrl(withBase(ogImage), Astro.site)
	: absoluteUrl(withBase(`/og-image/${slug}.png`), Astro.site);
const articleDate = updatedDate?.toISOString() ?? publishDate.toISOString();
const { remarkPluginFrontmatter } = await render(post);

const authorName = siteConfig.profile?.name ?? siteConfig.author;
const postUrl = absoluteUrl(`/posts/${slug}/`, Astro.site);

const eyebrowDate = formatEyebrowDate(publishDate);
const bylineDate = formatBylineDate(publishDate);

const readingTime: string =
	(remarkPluginFrontmatter as { minutesRead?: string })?.minutesRead ?? "";
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BlogPosting",
		headline: title,
		datePublished: articleDate,
		dateModified: updatedDate?.toISOString(),
		url: postUrl,
		author: {
			"@type": "Person",
			name: authorName,
		},
		description: description,
	}}
/>

<BaseLayout meta={{ articleDate, description, ogImage: ogImageUrl, title }}>
	<div
		class="reading-progress bg-accent pointer-events-none fixed top-0 left-0 z-[100] h-[2px] w-0 motion-safe:transition-[width] motion-safe:duration-[0.05s] motion-safe:ease-linear"
		id="reading-progress"
		aria-hidden="true"
	>
	</div>
	<div class="relative block">
		<div class="post-main mx-auto w-full max-w-[720px]" data-pagefind-body>
			<div id="blog-hero" class="post-header">
				<div
					class="post-eyebrow text-text/45 font-mono [font-feature-settings:'tnum'] text-[11px] font-medium tracking-[0.18em] uppercase [font-variant-numeric:tabular-nums] max-[420px]:mb-[18px]"
				>
					{eyebrowDate}
				</div>
				{
					draft && (
						<span class="draft-flag mb-3 inline-block font-mono text-[11.5px] tracking-[0.08em] text-[#c14a2b]">
							(rascunho)
						</span>
					)
				}
				<h1
					class="post-title text-text m-0 mb-3 font-serif leading-[1.1] font-normal tracking-[-0.022em] [text-wrap:balance] [overflow-wrap:break-word] break-words max-[720px]:text-[30px] max-[720px]:leading-[1.15] max-[420px]:text-[26px]"
					style="font-size: clamp(28px, 5.5vw, 46px)"
				>
					{title}
				</h1>
				<div class="post-meta mb-9">
					<p
						class="byline text-text-muted m-0 mb-7 font-serif [font-feature-settings:'tnum'] text-[15px] leading-[1.5] font-normal italic [font-variant-numeric:tabular-nums] max-[720px]:text-[15.5px] max-[420px]:mb-6 max-[420px]:text-[14.5px]"
					>
						{
							authorName && (
								<>
									por {authorName.toLowerCase()}
									<span class="sep text-faint mx-[6px] not-italic">·</span>
								</>
							)
						}{bylineDate}{
							readingTime && (
								<>
									<span class="sep text-faint mx-[6px] not-italic">·</span>
									{readingTime}
								</>
							)
						}
					</p>

					{
						siteConfig.profile?.avatar && (
							<div class="author-card border-hairline flex max-w-fit items-center gap-3 border-t pt-[14px]">
								<img
									src={siteConfig.profile.avatar}
									alt={authorName}
									class="author-avatar border-hairline bg-paper h-10 w-10 rounded-full border object-cover"
									width="40"
									height="40"
								/>
								<div class="author-info flex flex-col gap-[2px]">
									<span class="author-name text-text font-serif text-[15px] italic">
										{authorName.toLowerCase()}
									</span>
									<span class="author-role text-text/55 font-mono text-[11px] tracking-[0.08em] lowercase">
										everything is going to be okay...
									</span>
								</div>
							</div>
						)
					}
				</div>
				{
					!!tags?.length && (
						<div class="post-tags text-text/45 mb-10 font-mono text-[11.5px] tracking-[0.02em] break-words">
							{tags.map((tag, i) => (
								<>
									<span data-pagefind-filter="tag">{tag}</span>
									{i < tags.length - 1 && <span class="sep text-faint mx-[6px]">·</span>}
								</>
							))}
						</div>
					)
				}
			</div>

			{
				coverImage ? (
					<figure class="post-cover mb-9 p-0">
						<Image
							src={coverImage.src}
							alt={coverImage.alt}
							loading="eager"
							fetchpriority="high"
							decoding="async"
							widths={[480, 720, 960, 1280]}
							sizes="(max-width: 720px) 92vw, 696px"
							class="border-hairline bg-paper block h-auto max-h-[380px] w-full rounded border object-cover"
						/>
					</figure>
				) : (
					<hr class="rule bg-hairline ease motion-safe:ease mb-0 h-[1px] border-0 transition-[background-color] duration-[0.35s] motion-safe:transition-[background-color] motion-safe:duration-[0.35s]" />
				)
			}

			<article class="post-article prose prose-slate dark:prose-invert max-w-none font-serif">
				<slot />
			</article>

			<ShareButtons {...{ title, url: postUrl, description } as any} />

			<hr
				class="rule rule--footer bg-hairline ease motion-safe:ease mt-14 mb-7 h-[1px] border-0 transition-[background-color] duration-[0.35s] motion-safe:transition-[background-color] motion-safe:duration-[0.35s]"
			/>

			{
				(olderPost || newerPost) && (
					<nav
						class="post-pager mb-14 grid grid-cols-2 gap-x-12 gap-y-7 max-[720px]:mb-10 max-[720px]:grid-cols-1 max-[720px]:gap-y-[22px]"
						aria-label="More posts"
					>
						{olderPost && (
							<a
								class="pager-link prev motion-safe:ease block min-w-0 no-underline hover:-translate-x-0.5 motion-safe:transition-transform motion-safe:duration-[0.25s]"
								data-astro-prefetch
								href={withBase(`/posts/${olderPost.id}/`)}
							>
								<span class="pager-eyebrow text-text/50 mb-2 block font-mono text-[11px] font-medium tracking-[0.14em] uppercase before:content-['←_']">
									mais antigos
								</span>
								<span class="pager-title text-text motion-safe:ease group-hover/pager-link:text-accent block font-serif text-[17.5px] leading-[1.3] font-medium tracking-[-0.01em] [text-wrap:balance] [overflow-wrap:anywhere] break-words motion-safe:transition-colors motion-safe:duration-[0.2s]">
									{olderPost.data.title}
								</span>
							</a>
						)}
						{newerPost && (
							<a
								class="pager-link next motion-safe:ease block min-w-0 text-right no-underline hover:translate-x-0.5 motion-safe:transition-transform motion-safe:duration-[0.25s] max-[720px]:text-left"
								data-astro-prefetch
								href={withBase(`/posts/${newerPost.id}/`)}
							>
								<span class="pager-eyebrow text-text/50 mb-2 block font-mono text-[11px] font-medium tracking-[0.14em] uppercase after:content-['_→']">
									mais recentes
								</span>
								<span class="pager-title text-text motion-safe:ease block font-serif text-[17.5px] leading-[1.3] font-medium tracking-[-0.01em] [text-wrap:balance] [overflow-wrap:anywhere] break-words motion-safe:transition-colors motion-safe:duration-[0.2s]">
									{newerPost.data.title}
								</span>
							</a>
						)}
					</nav>
				)
			}
		</div>
	</div>

	<button
		aria-label="Ir para o topo"
		class="to-top-btn bg-accent-soft text-text-muted motion-safe:ease hover:border-hairline hover:text-accent invisible fixed right-4 bottom-8 z-90 flex h-10 w-10 translate-y-7 items-center justify-center rounded-full border border-transparent opacity-0 data-[show=true]:visible data-[show=true]:translate-y-0 data-[show=true]:opacity-100 motion-safe:transition-all motion-safe:duration-[0.3s] max-md:right-8 max-md:h-11 max-md:w-11"
		data-show="false"
		id="to-top-btn"
	>
		<svg
			aria-hidden="true"
			fill="none"
			focusable="false"
			stroke="currentColor"
			stroke-width="2"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
			class="h-5 w-5"
		>
			<path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round"></path>
		</svg>
	</button>
</BaseLayout>

<style is:global>
	.author-avatar {
		box-shadow: 0 0 0 1px hsl(var(--theme-bg));
	}

	.author-name {
		letter-spacing: -0.01em;
	}

	.post-article {
		--tw-prose-body: hsl(var(--theme-text));
		--tw-prose-headings: hsl(var(--theme-text));
		--tw-prose-links: hsl(var(--theme-accent));
	}

	.post-article h2,
	.post-article h3 {
		position: relative;
	}
	.post-article .heading-anchor {
		position: absolute;
		left: -1.25em;
		top: 0;
		bottom: 0;
		display: inline-flex;
		align-items: center;
		font-family: var(--font-mono);
		font-size: 0.7em;
		color: hsl(var(--theme-accent));
		opacity: 0;
		transition: opacity 0.18s ease;
		text-decoration: none;
		padding: 0 0.4em;
		background: transparent;
		border: 0;
		cursor: pointer;
	}
	@media (hover: hover) {
		.post-article h2:hover .heading-anchor,
		.post-article h3:hover .heading-anchor,
		.post-article .heading-anchor:focus-visible {
			opacity: 1;
		}
	}
	@media (hover: none) {
		.post-article .heading-anchor {
			opacity: 0.35;
			position: static;
			margin-left: 0.4em;
		}
	}
	@media (max-width: 720px) {
		.post-article .heading-anchor {
			position: static;
			margin-left: 0.4em;
			opacity: 0.35;
		}
	}

	.post-main > .rule {
		margin-bottom: 56px;
	}

	@media (max-width: 720px) {
		.post-main > .rule {
			margin-bottom: 32px;
		}
	}
	@media (max-width: 420px) {
		.post-main > .rule {
			margin-bottom: 26px;
		}
	}
</style>

<script>
	const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement | null;
	const heroEl = document.getElementById("blog-hero") as HTMLDivElement | null;
	if (scrollBtn && heroEl) {
		new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				scrollBtn.dataset.show = (!entry.isIntersecting).toString();
			});
		}).observe(heroEl);
		scrollBtn.addEventListener("click", () =>
			document.documentElement.scrollTo({ behavior: "smooth", top: 0 }),
		);
	}

	const progressBar = document.getElementById("reading-progress") as HTMLElement | null;
	if (progressBar) {
		const update = () => {
			const h = document.documentElement;
			const max = h.scrollHeight - h.clientHeight;
			const pct = max > 0 ? Math.min(100, (h.scrollTop / max) * 100) : 0;
			progressBar.style.width = pct + "%";
		};
		update();
		window.addEventListener("scroll", update, { passive: true });
		window.addEventListener("resize", update, { passive: true });
	}

	const lazyImgs = document.querySelectorAll<HTMLImageElement>('.post-article img[loading="lazy"]');
	if (lazyImgs.length && "IntersectionObserver" in window) {
		const io = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						(e.target as HTMLElement).dataset.in = "1";
						io.unobserve(e.target);
					}
				});
			},
			{ rootMargin: "120px 0px" },
		);
		lazyImgs.forEach((img) => io.observe(img));
	}

	const slugify = (s: string) =>
		s
			.toLowerCase()
			.trim()
			.replace(/[^a-z0-9]+/g, "-")
			.replace(/^-+|-+$/g, "");
	const usedIds = new Set<string>();
	document
		.querySelectorAll<HTMLHeadingElement>(".post-article h2, .post-article h3")
		.forEach((h) => {
			const baseId = h.id || slugify(h.textContent ?? "");
			if (!baseId) return;
			let id = baseId;
			for (let n = 2; usedIds.has(id); n++) id = `${baseId}-${n}`;
			usedIds.add(id);
			if (!h.id) h.id = id;

			const btn = document.createElement("button");
			btn.type = "button";
			btn.className = "heading-anchor";
			btn.setAttribute("aria-label", `Copiar link para ${h.textContent ?? "section"}`);
			btn.textContent = "#";
			btn.addEventListener("click", async () => {
				const url = `${location.origin}${location.pathname}#${id}`;
				try {
					await navigator.clipboard.writeText(url);
					btn.textContent = "✓";
					setTimeout(() => (btn.textContent = "#"), 1200);
				} catch {}
			});
			h.prepend(btn);
		});
</script>
