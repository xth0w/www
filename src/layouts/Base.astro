---
import BaseHead from "@/components/BaseHead.astro";
import SkipLink from "@/components/SkipLink.astro";
import Footer from "@/components/layout/Footer.astro";
import Header from "@/components/layout/Header.astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import { siteConfig } from "@/site-config";
import type { SiteMeta } from "@/types";

interface Props {
	meta: SiteMeta;
}

const {
	meta: { articleDate, description = siteConfig.description, ogImage, title },
} = Astro.props;

const safePadding =
	"padding-left: max(32px, env(safe-area-inset-left)); padding-right: max(32px, env(safe-area-inset-right)); padding-bottom: max(80px, env(safe-area-inset-bottom));";
---

<html class="[scrollbar-gutter:stable]" lang={siteConfig.lang} data-theme="dark">
	<head>
		<BaseHead articleDate={articleDate} description={description} ogImage={ogImage} title={title} />
	</head>

	<body
		class="bg-bg text-text m-0 flex min-h-dvh flex-col overflow-x-hidden font-serif text-[18px] leading-[1.62] antialiased max-[720px]:text-[17px] max-[420px]:text-[16.5px]"
	>
		<SkipLink />

		<div
			class="wrap mx-auto flex w-full max-w-[50rem] flex-1 flex-col pt-[28px] max-[420px]:pt-[14px] max-md:pt-[18px]"
			style={safePadding}
		>
			<Header />

			<main id="main" class="flex-1">
				<slot />
			</main>

			<Footer />
		</div>
		<SpeedInsights />
	</body>
</html>

<style is:global>
	.wrap {
		transition: padding 200ms ease;
	}

	@media (max-width: 720px) {
		.wrap {
			padding-left: max(22px, env(safe-area-inset-left));
			padding-right: max(22px, env(safe-area-inset-right));
			padding-bottom: max(56px, env(safe-area-inset-bottom));
		}
	}

	@media (max-width: 420px) {
		.wrap {
			padding-left: max(16px, env(safe-area-inset-left));
			padding-right: max(16px, env(safe-area-inset-right));
			padding-bottom: max(44px, env(safe-area-inset-bottom));
		}
	}
</style>
