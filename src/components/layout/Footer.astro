---
import { siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";

const year = new Date().getFullYear();
---

<footer
	class="site-footer border-hairline text-text/72 ease flex flex-wrap items-center justify-between gap-4 border-t pt-[22px] font-sans text-[12.5px] transition-[border-color] duration-[0.35s] max-[420px]:gap-3 max-[420px]:text-[11.5px]"
>
	<div class="left flex flex-wrap items-center gap-[18px]">
		<span>&copy; {year} {siteConfig.author}</span>
		{
			!siteConfig.hideThemeCredit && (
				<span class="theme-credit text-text/55 text-[11.5px]">
					🚀 Feito com{" "}
					<a
						href="https://astro.build/"
						rel="noopener"
						class="border-text/35 motion-safe:ease hover:text-accent border-b border-dotted text-inherit no-underline hover:border-current motion-safe:transition-colors motion-safe:duration-[0.2s]"
					>
						Astro
					</a>
					e
					<a
						href="https://github.com/AnjayGoel/astro-sienna"
						rel="noopener"
						class="border-text/35 motion-safe:ease hover:text-accent border-b border-dotted text-inherit no-underline hover:border-current motion-safe:transition-colors motion-safe:duration-[0.2s]"
					>
						astro-sienna
					</a>
				</span>
			)
		}
	</div>
	<div class="right">
		<a
			href={withBase("/rss.xml")}
			class="text-text-muted motion-safe:ease hover:text-accent no-underline motion-safe:transition-colors motion-safe:duration-[0.2s]"
		>
			RSS
		</a>
	</div>
</footer>
