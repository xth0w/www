---
import { showcase } from "@/data/showcase";
import { menuLinks, siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";
import ThemeToggle from "../ThemeToggle.astro";

const url = new URL(Astro.request.url);
const wordmark = siteConfig.title;

const visibleMenuLinks = menuLinks.filter((link) => {
	if (link.path === "/showcase/" && showcase.length === 0) return false;
	return true;
});

const isActive = (path: string) => {
	const target = withBase(path);
	if (path === "/") return url.pathname === target;
	return url.pathname === target || url.pathname.startsWith(target);
};

const navIcons: Record<string, string> = {
	"/": '<path d="M2.5 6.5 8 2l5.5 4.5V13a1 1 0 0 1-1 1h-2.5v-4h-4v4H3.5a1 1 0 0 1-1-1Z"/>',
	"/posts/":
		'<path d="M3 2.5h7l3 3V13a.5.5 0 0 1-.5.5h-9.5a.5.5 0 0 1-.5-.5V3a.5.5 0 0 1 .5-.5Z"/><path d="M10 2.5V5.5h3"/><path d="M5.5 8.5h5"/><path d="M5.5 11h3.5"/>',
	"/showcase/":
		'<rect x="2" y="4.5" width="12" height="8.5" rx="1"/><path d="M5.5 4.5V3a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v1.5"/>',
	"/about/":
		'<circle cx="8" cy="6" r="2.5"/><path d="M3 13c.6-2.4 2.6-3.5 5-3.5s4.4 1.1 5 3.5"/>',
};
---

<header class="site-header" id="main-header">
	<a href={withBase("/")} class="wordmark">{wordmark}</a>
	<div class="header-right">
		<nav class="nav" aria-label="Primary">
			{
				visibleMenuLinks.map((link) => (
					<a
						aria-current={isActive(link.path) ? "page" : false}
						class:list={[{ active: isActive(link.path) }]}
						data-astro-prefetch
						href={withBase(link.path)}
					>
						<svg
							aria-hidden="true"
							viewBox="0 0 16 16"
							fill="none"
							stroke="currentColor"
							stroke-width="1.5"
							stroke-linecap="round"
							stroke-linejoin="round"
							set:html={navIcons[link.path] ?? ""}
						/>
						<span>{link.title}</span>
					</a>
				))
			}
		</nav>
		<ThemeToggle />
	</div>
</header>

<style>
	.site-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 72px;
	}
	.wordmark {
		font-family: var(--font-serif);
		font-size: 17px;
		font-weight: 500;
		letter-spacing: -0.01em;
		color: hsl(var(--theme-text));
		transition: color 0.2s ease, border-color 0.2s ease;
	}
	.wordmark:hover {
		color: hsl(var(--theme-accent));
	}
	.header-right {
		display: flex;
		align-items: baseline;
		gap: 22px;
	}
	.nav {
		display: flex;
		align-items: baseline;
		gap: 22px;
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
	}
	.nav a {
		display: inline-block;
		position: relative;
		padding-bottom: 3px;
		transition: color 0.2s ease;
	}
	/* Indicator overhangs the text slightly so the underline isn't abrupt. */
	.nav a::after {
		content: "";
		position: absolute;
		left: -3px;
		right: -3px;
		bottom: 0;
		height: 1px;
		background: transparent;
	}
	.nav a svg {
		display: inline-block;
		width: 14px;
		height: 14px;
		stroke: currentColor;
		vertical-align: -2px;
		margin-right: 6px;
	}
	.nav a:hover {
		color: hsl(var(--theme-accent));
	}
	.nav a.active {
		color: hsl(var(--theme-text));
	}
	.nav a.active::after {
		background: hsl(var(--theme-accent));
	}

	@media (max-width: 720px) {
		.site-header {
			margin-bottom: 36px;
			display: grid;
			grid-template-columns: 1fr auto;
			grid-template-areas:
				"wordmark theme"
				"nav nav";
			align-items: center;
			column-gap: 14px;
			row-gap: 14px;
		}
		.wordmark { grid-area: wordmark; }
		.header-right { display: contents; }
		.theme-toggle { grid-area: theme; justify-self: end; }
		.nav {
			grid-area: nav;
			gap: 22px;
			font-size: 13px;
			flex-wrap: wrap;
			justify-content: flex-start;
		}
		.nav a {
			/* Add top tap padding; desktop rule keeps the indicator space below. */
			padding-top: 6px;
		}
		.nav a svg {
			width: 13px;
			height: 13px;
		}
	}

	@media (max-width: 420px) {
		.site-header {
			margin-bottom: 28px;
			row-gap: 12px;
		}
		.wordmark {
			font-size: 16px;
		}
		.nav {
			gap: 18px;
			font-size: 12.5px;
		}
		.nav a svg {
			display: none;
		}
	}
</style>
