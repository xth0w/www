---
import { menuLinks, siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";

const url = new URL(Astro.request.url);
const wordmark = siteConfig.title;

const isActive = (path: string) => {
	const target = withBase(path);
	if (path === "/") return url.pathname === target;
	return url.pathname === target || url.pathname.startsWith(target);
};
---

<header
	class="site-header mb-[64px] flex items-baseline justify-between gap-6 border-b border-hairline pb-5 max-md:mb-9 max-md:grid max-md:grid-cols-1 max-md:gap-y-[14px] max-[420px]:mb-7 max-[420px]:gap-y-3"
	id="main-header"
>
	<a
		href={withBase("/")}
		class="wordmark font-serif text-[17px] italic font-medium tracking-[-0.01em] text-text no-underline motion-safe:transition-colors motion-safe:duration-[0.2s] motion-safe:ease hover:text-accent max-[420px]:text-[16px]"
	>
		{wordmark}
	</a>
	<div class="header-right flex items-baseline gap-[22px]">
		<nav
			class="nav flex items-baseline gap-[18px] font-mono text-[12px] tracking-wide text-text/60 max-md:flex-wrap max-md:justify-start max-[420px]:gap-[14px]"
			aria-label="Primary"
		>
			{
				menuLinks.map((link) => (
					<a
						aria-current={isActive(link.path) ? "page" : false}
						class:list={[
							"relative inline-block px-0 pt-0 pb-[2px] no-underline motion-safe:transition-colors motion-safe:duration-[0.2s] motion-safe:ease hover:text-accent",
							{
								"text-text after:absolute after:-left-[3px] after:-right-[3px] after:bottom-0 after:h-px after:bg-accent":
									isActive(link.path),
							},
						]}
						data-astro-prefetch
						href={withBase(link.path)}
					>
						<span>{link.title}</span>
					</a>
				))
			}
		</nav>
	</div>
</header>
