---
interface Props {
	url: string;
}

const { url } = Astro.props;
---

<div class="share mx-0 mt-16 mb-0 flex justify-center max-[420px]:gap-[10px]">
	<div class="share-buttons inline-flex gap-[10px]">
		<button
			class="share-btn group bg-accent-soft text-accent motion-safe:ease hover:border-accent hover:bg-accent hover:text-bg focus-visible:border-accent focus-visible:bg-accent focus-visible:text-bg group-data-[copied=true]:border-accent group-data-[copied=true]:bg-accent group-data-[copied=true]:text-bg relative inline-flex h-[34px] w-[34px] cursor-pointer items-center justify-center rounded-full border border-transparent p-2 font-mono text-[11px] leading-[1.4] tracking-[0.06em] uppercase no-underline motion-safe:transition-all motion-safe:duration-[0.2s] max-[420px]:px-2 max-[420px]:py-1 max-[420px]:text-[10.5px]"
			type="button"
			data-share-copy
			data-url={url}
			aria-label="copiar link"
		>
			<svg
				class="icon-copy motion-safe:ease absolute inline-block h-[15px] w-[15px] flex-shrink-0 group-data-[copied=true]:scale-[0.6] group-data-[copied=true]:opacity-0 motion-safe:transition-all motion-safe:duration-[0.2s]"
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="1.8"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<rect x="9" y="9" width="11" height="11" rx="2"></rect>
				<path d="M5 15V6a2 2 0 0 1 2-2h9"></path>
			</svg>

			<svg
				class="icon-check motion-safe:ease absolute inline-block h-[15px] w-[15px] flex-shrink-0 scale-[0.6] opacity-0 group-data-[copied=true]:scale-100 group-data-[copied=true]:opacity-100 motion-safe:transition-all motion-safe:duration-[0.2s]"
				aria-hidden="true"
				focusable="false"
				width="14"
				height="14"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M20 6L9 17l-5-5"></path>
			</svg>

			<span
				class="sr-only absolute m-[-1px] h-px w-px overflow-hidden border-0 p-0 whitespace-nowrap"
				style="clip: rect(0, 0, 0, 0)"
				aria-live="polite"
				data-copy-status></span>
		</button>
	</div>
</div>

<style>
	.share-btn:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}
</style>

<script>
	document.querySelectorAll<HTMLButtonElement>("[data-share-copy]").forEach((btn) => {
		const status = btn.querySelector<HTMLElement>("[data-copy-status]");
		let resetTimeout: ReturnType<typeof setTimeout> | undefined;

		btn.addEventListener("click", async () => {
			const url = btn.dataset.url ?? window.location.href;

			try {
				await navigator.clipboard.writeText(url);
			} catch (error) {
				console.error("failed to copy", error);
				return;
			}

			clearTimeout(resetTimeout);

			btn.dataset.copied = "true";
			btn.setAttribute("aria-label", "copiado");
			if (status) status.textContent = "copiado";

			resetTimeout = setTimeout(() => {
				delete btn.dataset.copied;
				btn.setAttribute("aria-label", "copiar link");
				if (status) status.textContent = "";
			}, 1200);
		});
	});
</script>
