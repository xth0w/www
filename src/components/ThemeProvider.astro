{/* Inlined to avoid FOUC — this is a parser-blocking script. */}
<script is:inline>
	(() => {
		try {
			const s = localStorage.getItem("theme");
			const d = window.matchMedia("(prefers-color-scheme: dark)").matches;
			document.documentElement.dataset.theme = s || (d ? "dark" : "light");
		} catch {}
	})();

	addEventListener("DOMContentLoaded", () => {
		requestAnimationFrame(() => document.documentElement.classList.add("theme-ready"));
	});

	const lightModePref = window.matchMedia("(prefers-color-scheme: light)");

	function setTheme(newTheme) {
		if (newTheme !== "light" && newTheme !== "dark") return;
		const root = document.documentElement;
		if (newTheme === root.getAttribute("data-theme")) return;
		root.setAttribute("data-theme", newTheme);
		const meta = document.querySelector("meta[name='theme-color']");
		if (meta && document.body) {
			const bg = getComputedStyle(document.body).getPropertyValue("--theme-bg");
			meta.setAttribute("content", `hsl(${bg})`);
		}
		try { localStorage.setItem("theme", newTheme); } catch {}
	}

	document.addEventListener("theme-change", (e) => setTheme(e.detail.theme));
	lightModePref.addEventListener("change", (e) => setTheme(e.matches ? "light" : "dark"));
</script>
