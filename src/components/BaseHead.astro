---
import { siteConfig } from "@/site-config";
import type { SiteMeta } from "@/types";
import { withBase } from "@/utils/path";
import "../styles/global.css";
import newsreaderLatin from "@fontsource-variable/newsreader/files/newsreader-latin-wght-normal.woff2?url";
import interLatin from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import jetbrainsMonoLatin from "@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url";

type Props = SiteMeta;

const { articleDate, description, title, noindex, ogImage: ogImageProp } = Astro.props;

const siteTitle = title === siteConfig.title ? title : `${title} · ${siteConfig.title}`;
const pageDescription = description ?? siteConfig.description;

if (!Astro.site) {
	throw new Error(
		"`site` não está configurado em astro.config.*. É necessário para gerar URLs absolutas de canonical/OG.",
	);
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage =
	ogImageProp ??
	new URL(withBase(`/og-image${Astro.url.pathname.replace(/\/$/, "")}.png`), Astro.site).toString();

const robotsContent = noindex ? "noindex,nofollow" : "index,follow";
---

<meta charset="utf-8" />
<meta content="width=device-width, initial-scale=1.0" name="viewport" />
<title>{siteTitle}</title>

<link href={withBase("/favicon.ico")} rel="icon" type="image/png" />
<link rel="apple-touch-icon" sizes="180x180" href={withBase("/icons/apple-touch-icon.png")} />
<link rel="icon" type="image/png" sizes="32x32" href={withBase("/icons/favicon-32x32.png")} />
<link rel="icon" type="image/png" sizes="16x16" href={withBase("/icons/favicon-16x16.png")} />
<link rel="manifest" href={withBase("/site.webmanifest")} />

{
	import.meta.env.PROD && (
		<>
			<link rel="sitemap" href={withBase("/sitemap-index.xml")} />
		</>
	)
}
<link href={canonicalURL} rel="canonical" />

<meta content={siteTitle} name="title" />
<meta content={pageDescription} name="description" />
<meta content={siteConfig.author} name="author" />
<meta content={robotsContent} name="robots" />
<meta content={robotsContent} name="googlebot" />

<link rel="preload" as="font" type="font/woff2" href={newsreaderLatin} crossorigin />
<link rel="preload" as="font" type="font/woff2" href={interLatin} crossorigin />
<link rel="preload" as="font" type="font/woff2" href={jetbrainsMonoLatin} crossorigin />

<meta content="#131110" name="theme-color" />

<!-- Open Graph -->
<meta content={articleDate ? "article" : "website"} property="og:type" />
<meta content={title} property="og:title" />
<meta content={pageDescription} property="og:description" />
<meta content={canonicalURL} property="og:url" />
<meta content={siteConfig.title} property="og:site_name" />
<meta content={siteConfig.ogLocale} property="og:locale" />
<meta content={ogImage} property="og:image" />
<meta content="image/png" property="og:image:type" />
<meta content={siteTitle} property="og:image:alt" />
<meta content="1200" property="og:image:width" />
<meta content="630" property="og:image:height" />
{
	articleDate && (
		<>
			<meta content={siteConfig.author} property="article:author" />
			<meta content={articleDate} property="article:published_time" />
		</>
	)
}

<!-- Twitter / X Card -->
<meta content="summary_large_image" name="twitter:card" />
<meta content={canonicalURL} name="twitter:url" />
<meta content={title} name="twitter:title" />
<meta content={pageDescription} name="twitter:description" />
<meta content={ogImage} name="twitter:image" />
<meta content={siteTitle} name="twitter:image:alt" />
{siteConfig.twitterHandle && <meta content={siteConfig.twitterHandle} name="twitter:site" />}

<link
	href={withBase("/rss.xml")}
	rel="alternate"
	title={siteConfig.title}
	type="application/rss+xml"
/>

<meta content={Astro.generator} name="generator" />
