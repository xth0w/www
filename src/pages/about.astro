---
import { getEntry, render } from "astro:content";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig, socials } from "@/site-config";
import { absoluteUrl } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const entry = await getEntry("page", "about");
if (!entry) throw new Error("Missing src/content/page/about.md");
const { Content } = await render(entry);

const profile = siteConfig.profile;
const authorName = profile?.name ?? siteConfig.author;

const meta = {
	description: entry.data.description ?? `${authorName} — sobre mim.`,
	title: entry.data.title,
};

const personSameAs = socials.filter((s) => !s.url.startsWith("mailto:")).map((s) => s.url);

const avatarUrl = profile?.avatar ? absoluteUrl(profile.avatar, Astro.site) : undefined;
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "ProfilePage",
	}}
/>

<PageLayout meta={meta}>
	<section class="about mb-16" aria-labelledby="about-label">
		<div class="section-label" id="about-label">Sobre</div>
		{
			profile?.avatar && (
				<img
					src={profile.avatar}
					alt={authorName}
					class="mb-6 rounded-full"
					width="72"
					height="72"
				/>
			)
		}
		<div class="bio prose prose-slate dark:prose-invert max-w-none font-serif">
			<Content />
		</div>
	</section>
</PageLayout>
