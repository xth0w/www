---
import { getAllPosts, getPostSortDate, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig, socials } from "@/site-config";
import { Icon } from "astro-icon/components";
import { absoluteUrl, withBase } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts);
const TIMELINE_LIMIT = 5;
const timelinePosts = allPostsByDate.slice(0, TIMELINE_LIMIT);
const featured = timelinePosts[0];
const rest = timelinePosts.slice(1);
const archiveCount = allPosts.length;

const profile = siteConfig.profile;
const siteUrl = (path: string) => absoluteUrl(path, Astro.site);

const featuredDate = featured ? getPostSortDate(featured) : null;
const featuredIso = featuredDate ? featuredDate.toISOString() : "";
const featuredLabel = featuredDate ? featuredDate.toLocaleDateString("pt-PT") : "";
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Início",
				item: siteUrl("/"),
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Sobre",
				item: siteUrl("/about"),
			},
			{
				"@type": "ListItem",
				position: 3,
				name: "Publicações",
				item: siteUrl("/posts"),
			},
		],
	}}
/>

<PageLayout meta={{ title: "Início", description: siteConfig.description }}>
	<section class="hero mb-[76px] max-[720px]:mb-14 max-[420px]:mb-12">
		<div class="hero-header mb-4 flex items-center gap-4 max-[420px]:gap-3">
			{
				profile?.avatar && (
					<img
						src={profile.avatar}
						alt={siteConfig.author}
						class="avatar h-14 w-14 flex-shrink-0 rounded-full border border-hairline object-cover motion-safe:transition-all motion-safe:duration-[0.2s] motion-safe:ease hover:-translate-y-px hover:border-accent max-[420px]:h-[46px] max-[420px]:w-[46px]" style="box-shadow: 0 0 0 3px hsl(var(--theme-bg))"
						width="56"
						height="56"
					/>
				)
			}
			<div class="hero-title flex flex-col gap-1">
				<h1 class="m-0 font-serif font-bold leading-[0.95] tracking-[-0.05em] text-text [text-wrap:balance]" style="font-size: clamp(2.2rem, 6vw, 4.2rem)">
					{siteConfig.author}
				</h1>
				<span class="font-mono text-[10.5px] lowercase tracking-[0.12em] text-accent max-[420px]:text-[10px]">everything is going to be okay...</span>
			</div>
		</div>
		<p class="mb-[22px] mt-0 max-w-[60ch] text-[18px] leading-[1.65] text-text [text-wrap:pretty] [white-space:pre-line] max-[720px]:text-[18px] max-[420px]:text-[17px]">
			{siteConfig.description}
		</p>
		<div class="socials mt-4 flex flex-wrap items-center gap-[10px] font-sans text-[13px] text-text/72 max-[420px]:text-[12.5px]">
			{
				socials.map((s, i) => (
					<>
						<a
							href={s.url}
							rel="noreferrer"
							target="_blank"
							aria-label={s.name}
							class="text-text-muted motion-safe:transition-colors motion-safe:duration-[0.2s] motion-safe:ease hover:text-accent"
						>
							<Icon name={s.icon} size={18} />
						</a>
					</>
				))
			}
		</div>
	</section>

	<section class="writing mb-[84px] max-[420px]:mb-16" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">escritos</div>
		<div class="timeline">
			{
				featured && (
					<a
						class="post featured"
						data-astro-prefetch
						href={withBase(`/posts/${featured.id}/`)}
						style="--i: 0"
					>
						<div class="post-rail max-md:hidden">
							<time class="post-date" datetime={featuredIso}>
								{featuredLabel}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body pb-14 max-md:border-b max-md:border-hairline max-md:pb-6 max-md:mb-1">
							<div class="post-stamp mb-3 font-mono text-[10.5px] lowercase tracking-[0.12em] text-accent">
								mais recente · {featuredLabel}
							</div>
							<h2 class="post-title m-0 mb-[14px] font-medium leading-[1.14] tracking-[-0.03em] text-text [text-wrap:balance] [word-wrap:break-word] max-md:text-[22px] max-md:leading-[1.2] max-md:mb-[10px] max-md:tracking-[-0.015em] max-[420px]:text-[17px]" style="font-size: clamp(1.8rem, 4vw, 2.4rem)">
								{featured.data.title}
							</h2>
							<p class="post-excerpt m-0 mb-4 max-w-[58ch] text-[18px] leading-[1.62] text-text-muted [word-wrap:break-word] [overflow-wrap:break-word] max-md:text-[15.5px] max-md:leading-[1.55] max-md:mb-[10px] max-[420px]:text-[15px]">
								{featured.data.description}
							</p>
							{!!featured.data.tags?.length && (
								<div class="post-meta font-mono text-[11.5px] text-text/72 [font-feature-settings:'tnum'] [font-variant-numeric:tabular-nums] max-md:text-[11px]">
									{featured.data.tags.map((t, i) => (
										<Fragment>
											{i > 0 && <span class="dot mx-2 text-faint">·</span>}
											<span>{t}</span>
										</Fragment>
									))}
								</div>
							)}
						</div>
					</a>
				)
			}

			{
				rest.map((p, idx) => (
					<a
						class="post"
						data-astro-prefetch
						href={withBase(`/posts/${p.id}/`)}
						style={`--i: ${idx + 1}`}
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{getPostSortDate(p).toLocaleDateString("pt-PT")}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h3 class="post-title">{p.data.title}</h3>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}

			<div class="archive-link col-start-2 mt-2 font-sans text-[13.5px] text-text/72 max-md:mt-0">
				<a
					data-astro-prefetch
					href={withBase("/posts/")}
					class="inline-block px-0 py-[6px] text-text-muted underline decoration-1 underline-offset-[3px] decoration-text/35 motion-safe:transition-all motion-safe:duration-[0.2s] motion-safe:ease hover:text-accent hover:decoration-accent hover:translate-x-0.5"
				>
					ver todas as {archiveCount} publicações →
				</a>
			</div>
		</div>
	</section>
</PageLayout>

<style>
	.socials a:focus-visible,
	.archive-link a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	.post.featured .post-dot {
		--rail-dot-size: 11px;
		border-color: hsl(var(--theme-text-muted));
	}
	.post.featured:hover .post-dot {
		background: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}
</style>
