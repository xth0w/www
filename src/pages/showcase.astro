---
import { showcase } from "@/data/showcase";
import PageLayout from "@/layouts/Base.astro";
import { Schema } from "astro-seo-schema";

const siteUrl = (path: string) => new URL(path, Astro.site).toString();
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Home",
				item: siteUrl("/"),
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "Showcase",
				item: siteUrl("/showcase"),
			},
		],
	}}
/>

<PageLayout meta={{ title: "Showcase" }}>
	<section class="work" aria-labelledby="work-label">
		<div class="section-label" id="work-label">Showcase</div>
		<p class="intro">
			A handful of projects I've built.
		</p>
		<ul class="work-list">
			{
				showcase.map((item) => (
					<li>
						<a href={item.href} rel="noreferrer" target="_blank">
							<div class="head">
								<span class="name">{item.name}</span>
								<span class="stack">{item.stack}</span>
								{item.badge && <span class="badge">{item.badge}</span>}
							</div>
							<p>{item.desc}</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<style>
	.work {
		margin-bottom: 88px;
	}
	.intro {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin: 0 0 36px;
		max-width: 60ch;
		text-wrap: pretty;
	}

	@media (max-width: 720px) {
		.intro {
			font-size: 17px;
			margin-bottom: 28px;
		}
	}
	@media (max-width: 420px) {
		.work {
			margin-bottom: 56px;
		}
		.intro {
			font-size: 16.5px;
		}
	}
</style>
