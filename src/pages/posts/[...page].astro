---
import type { CollectionEntry } from "astro:content";
import { getAllPosts, getPostSortDate, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { withBase } from "@/utils/path";
import type { GetStaticPaths, Page } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const MAX_POSTS_PER_PAGE = 50;
	const allPosts = await getAllPosts();
	const allPostsByDate = sortMDByDate(allPosts);
	return paginate(allPostsByDate, { pageSize: MAX_POSTS_PER_PAGE });
}) satisfies GetStaticPaths;

interface Props {
	page: Page<CollectionEntry<"post">>;
}

const { page } = Astro.props;

const meta = {
	description: "arquivo de textos, notas e reflexões",
	title: "posts",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← mais recentes",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "mais antigos →",
			url: page.url.next,
		},
	}),
};

const totalCount = page.total;
---

<PageLayout meta={meta}>
	<section class="writing mb-[72px] max-[420px]:mb-12" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">
			{totalCount} {totalCount === 1 ? "texto" : "textos"}
		</div>
		<div class="timeline">
			{
				page.data.map((p, idx) => (
					<a
						class="post"
						data-astro-prefetch
						href={withBase(`/posts/${p.id}/`)}
						style={`--i: ${idx}`}
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{getPostSortDate(p).toLocaleDateString("pt-PT", {
									year: "numeric",
									month: "2-digit",
									day: "2-digit",
								})}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h2 class="post-title">{p.data.title}</h2>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}
		</div>
		{
			(paginationProps.prevUrl || paginationProps.nextUrl) && (
				<nav class="pagination col-start-2 mt-10 flex items-center justify-between gap-6 border-t border-hairline pt-6 max-md:mt-6" aria-label="Paginação">
					{paginationProps.prevUrl && (
						<a
							class="pag-link prev mr-auto inline-block px-1 py-2 font-mono text-[11px] uppercase tracking-[0.12em] text-text-muted underline decoration-1 underline-offset-[3px] decoration-text/35 motion-safe:transition-all motion-safe:duration-[0.2s] motion-safe:ease hover:text-accent hover:decoration-accent hover:translate-x-0.5"
							data-astro-prefetch
							href={paginationProps.prevUrl.url}
						>
							{paginationProps.prevUrl.text}
						</a>
					)}
					{paginationProps.nextUrl && (
						<a
							class="pag-link next ml-auto inline-block px-1 py-2 font-mono text-[11px] uppercase tracking-[0.12em] text-text-muted underline decoration-1 underline-offset-[3px] decoration-text/35 motion-safe:transition-all motion-safe:duration-[0.2s] motion-safe:ease hover:text-accent hover:decoration-accent hover:-translate-x-0.5"
							data-astro-prefetch
							href={paginationProps.nextUrl.url}
						>
							{paginationProps.nextUrl.text}
						</a>
					)}
				</nav>
			)
		}
	</section>
</PageLayout>

<style>
	.pag-link:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
</style>
