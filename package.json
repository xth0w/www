{
  "name": "astro-sienna",
  "version": "0.3.0",
  "description": "A minimal Astro blog template — serif typography, dark mode, RSS, OG images, optional Giscus comments and analytics.",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "postbuild": "pagefind --site dist",
    "build:check": "astro check && astro build",
    "preview": "astro preview",
    "lint": "prettier --check \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
    "format": "prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.0",
    "@astrojs/mdx": "7.0.0",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@playform/compress": "^0.2.3",
    "astro": "7.0.4",
    "astro-expressive-code": "^0.44.0",
    "astro-seo-schema": "^7.0.0",
    "astro-webmanifest": "^1.0.0",
    "hastscript": "^9.0.1",
    "katex": "^0.16.47",
    "mdast-util-directive": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^4.0.0",
    "remark-math": "^6.0.0",
    "satori": "0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.35.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "4.3.2",
    "@types/hast": "^3.0.4",
    "@types/mdast": "^4.0.4",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "reading-time": "^1.5.0",
    "rehype-unwrap-images": "^1.0.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "sharp": "^0.35.3"
  }
}
